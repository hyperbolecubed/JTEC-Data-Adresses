  <XDFCONSTANT uniqueid="0x7001">
    <title>MAP Offset</title>
    <description>16-bit offset added after MAP ADC raw * MAP Scaling. Used by interp routine $10044 (MAP ADC to scaled byte). Formula: out = clamp255((raw_MAP * $266D) + $266B). v130 = 0x15DC (5596).</description>
    <CATEGORYMEM index="0" category="9" />
    <EMBEDDEDDATA mmedaddress="0x266B" mmedelementsizebits="16" mmedmajorstridebits="0" mmedminorstridebits="0" />
    <units>raw</units>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="X">
      <VAR id="X" />
    </MATH>
  </XDFCONSTANT>
